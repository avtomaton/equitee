# ═══════════════════════════════════════════════════════════
# Equitee Backend Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your deployment.
# Lines starting with # are comments — remove # to activate.

# ── REQUIRED FOR BOTH MODES ────────────────────────────────
DATABASE_URL=sqlite:///real_estate.db

# ── SET TO "saas" FOR MULTI-TENANT MODE ────────────────────
# TENANCY_MODE=single

# ── REQUIRED ONLY WHEN TENANCY_MODE=saas ───────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/equitee
# JWT_SECRET=change-this-to-a-random-32-byte-hex-string
# Generate with: python3 -c 'import secrets; print(secrets.token_hex(32))'

# ── GOOGLE OAUTH (optional, SaaS mode) ─────────────────────
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# ── EMAIL / SMTP (optional, SaaS mode) ─────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true
# MAIL_FROM=noreply@yourdomain.com
# APP_BASE_URL=http://localhost:5173

# ── EMAIL VERIFICATION ─────────────────────────────────────
# EMAIL_VERIFICATION_EXPIRY_HOURS=24

# ── OPTIONAL TUNING ────────────────────────────────────────
# JWT_EXPIRATION_HOURS=1
# JWT_REFRESH_EXPIRATION_DAYS=30
# DEFAULT_PLAN=free
# FLASK_DEBUG=false
