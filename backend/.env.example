# ═══════════════════════════════════════════════════════════
# Equitee Backend Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your deployment.
# Lines starting with # are comments — remove # to activate.

# ── REQUIRED FOR BOTH MODES ────────────────────────────────
DATABASE_URL=sqlite:///real_estate.db

# ── SET TO "saas" FOR MULTI-TENANT MODE ────────────────────
# TENANCY_MODE=single

# ── REQUIRED ONLY WHEN TENANCY_MODE=saas ───────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/equitee
# JWT_SECRET=change-this-to-a-random-32-byte-hex-string
# Generate with: python3 -c 'import secrets; print(secrets.token_hex(32))'

# ── OPTIONAL TUNING ────────────────────────────────────────
# JWT_EXPIRATION_HOURS=1
# JWT_REFRESH_EXPIRATION_DAYS=30
# DEFAULT_PLAN=free
# FLASK_DEBUG=false
