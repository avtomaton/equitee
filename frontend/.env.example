# Equitee Frontend Configuration
# Copy this file to .env and adjust values for your deployment.

# ── API URL (proxied by Vite dev server) ─────────────────────
# In development, Vite proxies /api to the Flask backend.
# In production, this should match your backend's base URL.
VITE_API_URL=/api

# ── SET TO "saas" FOR MULTI-TENANT MODE ─────────────────────
# If unset or 'single', the app runs in self-hosted mode (no auth).
# VITE_TENANCY_MODE=single
