# ── Equitee SaaS Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.
# This file is used by docker-compose.

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================

# Which nginx vhost config to use: "production.conf" or "development.conf"
VHOST=production.conf

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Database password (used by both PostgreSQL and the backend)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSWORD=change_me_to_a_strong_password

# JWT secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# IMPORTANT: Use a strong, unique secret in production!
JWT_SECRET=your_jwt_secret_here_generate_with_python_command

# =============================================================================
# EMAIL CONFIGURATION (Optional but recommended)
# =============================================================================

# SMTP server settings for sending verification emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true

# From address for emails
MAIL_FROM=noreply@yourdomain.com

# =============================================================================
# GOOGLE OAUTH (Optional)
# =============================================================================

# Google OAuth credentials from Google Cloud Console
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret