# Equitee SaaS Mode Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Application mode - must be 'saas' for multi-tenant mode
TENANCY_MODE=saas

# PostgreSQL database URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://equitee:your_secure_password@localhost:5432/equitee

# JWT secret key - generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# IMPORTANT: Use a strong, unique secret in production!
JWT_SECRET=your_jwt_secret_here_generate_with_python_command

# =============================================================================
# REDIS (Required for multi-process deployments)
# =============================================================================

# Redis URL for token blacklist and rate limiting
# Format: redis://user:password@host:port/db
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# EMAIL CONFIGURATION (Optional but recommended)
# =============================================================================

# SMTP server settings for sending verification emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true

# From address for emails
MAIL_FROM=noreply@yourdomain.com

# How long email verification links are valid (hours)
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# =============================================================================
# GOOGLE OAUTH (Optional)
# =============================================================================

# Google OAuth credentials from Google Cloud Console
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Flask secret key for sessions
SECRET_KEY=your_flask_secret_key

# CORS origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# =============================================================================
# RATE LIMITING
# =============================================================================

# Default rate limits (applied when Redis is configured)
# RATE_LIMIT_DEFAULT=200 per day,50 per hour